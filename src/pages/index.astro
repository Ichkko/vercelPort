---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Nav from "../components/Nav.astro";
import Card from "../components/Card.astro";
import Education from "../components/Education.astro";
import Contact from "./contact.astro";
import LanguageToggle from "../components/LanguageToggle.astro";
---

<Layout
  title="G. Ichko | Portfolio"
  description="Junior full stack developer portfolio focused on Astro, Spring Boot, MySQL, and Flutter projects."
>
  <div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(16,185,129,0.16),_transparent_30%),linear-gradient(180deg,#f6fff8_0%,#fffdf7_45%,#f8fafc_100%)]">
    <div class="mx-auto flex w-full max-w-7xl gap-8 px-4 py-8 md:px-6 lg:px-8">
      <Nav />

      <main class="w-full space-y-12">
        <div class="flex justify-end lg:hidden">
          <LanguageToggle />
        </div>

        <Header />

        <section id="skills" class="rounded-[2rem] border border-white/70 bg-white/90 p-8 shadow-[0_18px_60px_rgba(15,23,42,0.06)]">
          <p data-lang="en" class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700">Core Skills</p>
          <p data-lang="mn" class="hidden text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700">Гол ур чадвар</p>
          <h2 data-lang="en" class="mt-3 text-3xl font-bold text-slate-900">Technology stack with practical focus</h2>
          <h2 data-lang="mn" class="hidden mt-3 text-3xl font-bold text-slate-900">Практик хэрэглээтэй технологийн стек</h2>

          <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            <div class="rounded-[1.5rem] bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Frontend</h3>
              <p data-lang="en" class="mt-3 text-sm leading-7 text-slate-600">Astro, Tailwind CSS, JavaScript, responsive layout, component-based UI.</p>
              <p data-lang="mn" class="hidden mt-3 text-sm leading-7 text-slate-600">Astro, Tailwind CSS, JavaScript, responsive layout, component-based UI.</p>
            </div>
            <div class="rounded-[1.5rem] bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Backend</h3>
              <p data-lang="en" class="mt-3 text-sm leading-7 text-slate-600">Spring Boot, REST API design, JWT authentication, MVC architecture.</p>
              <p data-lang="mn" class="hidden mt-3 text-sm leading-7 text-slate-600">Spring Boot, REST API дизайн, JWT authentication, MVC architecture.</p>
            </div>
            <div class="rounded-[1.5rem] bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Database</h3>
              <p data-lang="en" class="mt-3 text-sm leading-7 text-slate-600">MySQL, JPA, Hibernate, entity modeling, and data persistence flows.</p>
              <p data-lang="mn" class="hidden mt-3 text-sm leading-7 text-slate-600">MySQL, JPA, Hibernate, entity загварчлал, өгөгдөл хадгалалтын урсгал.</p>
            </div>
            <div class="rounded-[1.5rem] bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Mobile</h3>
              <p data-lang="en" class="mt-3 text-sm leading-7 text-slate-600">Flutter for mobile-first interfaces and cross-platform app development.</p>
              <p data-lang="mn" class="hidden mt-3 text-sm leading-7 text-slate-600">Flutter ашиглан mobile-first интерфэйс болон cross-platform апп хөгжүүлэлт.</p>
            </div>
            <div class="rounded-[1.5rem] bg-slate-50 p-5">
              <h3 class="text-lg font-semibold text-slate-900">Tools</h3>
              <p data-lang="en" class="mt-3 text-sm leading-7 text-slate-600">Git, GitHub, Postman, Vercel, and collaborative team workflows.</p>
              <p data-lang="mn" class="hidden mt-3 text-sm leading-7 text-slate-600">Git, GitHub, Postman, Vercel болон багийн хамтын ажлын урсгал.</p>
            </div>
            <div class="rounded-[1.5rem] bg-slate-50 p-5">
              <h3 data-lang="en" class="text-lg font-semibold text-slate-900">Learning Now</h3>
              <h3 data-lang="mn" class="hidden text-lg font-semibold text-slate-900">Суралцаж буй</h3>
              <p data-lang="en" class="mt-3 text-sm leading-7 text-slate-600">Deeper system design thinking, better project architecture, and production-ready polish.</p>
              <p data-lang="mn" class="hidden mt-3 text-sm leading-7 text-slate-600">Илүү гүн system design сэтгэлгээ, сайн project architecture, production-ready polish.</p>
            </div>
          </div>
        </section>

        <Card />
        <Education />
        <Contact />
      </main>
    </div>
  </div>
</Layout>
