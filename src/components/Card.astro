---
const projects = [
  {
    title: "WoTour",
    stack: "Spring Boot, MySQL, JWT, REST API",
    image: "/travel.png",
    href: "https://github.com/Ichkko/travelguide",
    summary:
      "Built the backend for a travel platform with authentication, structured API endpoints, and database integration for user flows.",
    impact:
      "Shows backend fundamentals, API design, and practical authentication work.",
  },
  {
    title: "Movie Finder UI",
    stack: "Astro, Tailwind CSS, Responsive UI",
    image: "/kino.png",
    href: "https://github.com/Ichkko",
    summary:
      "Designed a clean browsing interface focused on layout hierarchy, discoverability, and responsive presentation.",
    impact:
      "Highlights frontend structure, component thinking, and mobile-friendly design decisions.",
  },
  {
    title: "Personal Portfolio",
    stack: "Astro, Tailwind CSS, Vercel",
    image: "/gg.png",
    href: "https://github.com/Ichkko",
    summary:
      "Created and iterated on a portfolio that presents skills, selected work, and career direction in a focused format.",
    impact:
      "Demonstrates personal branding, deployment workflow, and static site optimization.",
  },
];
---

<section id="projects" class="mt-12">
  <div class="flex items-end justify-between gap-4">
    <div>
      <p data-lang="en" class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700">Featured Work</p>
      <p data-lang="mn" class="hidden text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700">Онцлох ажил</p>
      <h2 data-lang="en" class="mt-3 text-3xl font-bold text-slate-900">Projects that show how I build</h2>
      <h2 data-lang="mn" class="hidden mt-3 text-3xl font-bold text-slate-900">Миний хэрхэн ажилладгийг харуулах төслүүд</h2>
    </div>
    <a href="https://github.com/Ichkko" target="_blank" rel="noreferrer" class="hidden rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-emerald-700 hover:text-emerald-700 md:inline-flex">
      <span data-lang="en">See More on GitHub</span>
      <span data-lang="mn" class="hidden">GitHub дээр үргэлжлүүлэн үзэх</span>
    </a>
  </div>

  <div class="mt-8 grid gap-6 xl:grid-cols-3">
    {projects.map((project) => (
      <a
        href={project.href}
        target="_blank"
        rel="noreferrer"
        class="group rounded-[1.75rem] border border-white/70 bg-white/90 p-4 shadow-[0_18px_60px_rgba(15,23,42,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_26px_80px_rgba(15,23,42,0.12)]"
      >
        <img
          src={project.image}
          alt={project.title}
          class="h-48 w-full rounded-[1.25rem] object-cover"
        />
        <div class="p-2">
          <h3 class="mt-4 text-xl font-semibold text-slate-900">{project.title}</h3>
          <p class="mt-2 text-sm font-medium text-emerald-700">{project.stack}</p>
          <p class="mt-4 text-sm leading-6 text-slate-600">{project.summary}</p>
          <p class="mt-4 text-sm leading-6 text-slate-500">{project.impact}</p>
          <p data-lang="en" class="mt-5 text-sm font-semibold text-slate-900 transition group-hover:text-emerald-700">
            Open Project
          </p>
          <p data-lang="mn" class="hidden mt-5 text-sm font-semibold text-slate-900 transition group-hover:text-emerald-700">
            Төслийг үзэх
          </p>
        </div>
      </a>
    ))}
  </div>
</section>

